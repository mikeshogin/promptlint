# promptlint routing configuration
# Copy to .promptlint.yaml in your project root

tiers:
  - name: haiku
    max_complexity: low
    max_tokens: 500
    cost_per_1k: 0.80

  - name: sonnet
    max_complexity: medium
    max_tokens: 5000
    cost_per_1k: 3.00

  - name: opus
    max_complexity: high
    max_tokens: 100000
    cost_per_1k: 15.00

default_tier: sonnet
